# ─── CivicCompass Backend — Environment Variables ─────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Google Gemini API Key (required for the AI explanation layer)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps API Key (for geocoding polling booths)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Cloud Project ID (for Firestore)
GCP_PROJECT_ID=your_gcp_project_id_here

# Server port
PORT=8080

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:3000

# Environment mode
NODE_ENV=development

# Set to 'true' to use local in-memory mock data instead of Firestore
USE_LOCAL_DATA=true

# Path to GCP service account key (only for local Firestore access)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
