{
  "name": "civiccompass-backend",
  "version": "1.0.0",
  "description": "CivicCompass Phase 1 Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node src/scripts/seedFirestore.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:report": "jest --forceExit --detectOpenHandles --json --outputFile=test-results.json && node tests/generateReport.js",
    "test:smoke": "GEMINI_SMOKE=true jest tests/services/geminiSmoke.test.js --testTimeout=30000 --forceExit"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.3.1",
    "@google/generative-ai": "^0.7.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": ["/node_modules/", "setup.js"],
    "testTimeout": 15000
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
